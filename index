<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Pickleball Ontario — Find Players, Coaches & Tournaments</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --lime: #c8f135;
    --orange: #ff6b1a;
    --dark: #0d0f0a;
    --card-bg: #161a10;
    --border: rgba(200,241,53,0.18);
    --muted: #8a9070;
    --white: #f2f4ea;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--dark);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── HERO ── */
  header {
    position: relative;
    padding: 56px 32px 40px;
    text-align: center;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(200,241,53,.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .badge {
    display: inline-block;
    background: var(--lime);
    color: var(--dark);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
    margin-bottom: 18px;
  }
  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 9vw, 110px);
    line-height: .92;
    letter-spacing: .02em;
    color: var(--white);
  }
  h1 span { color: var(--lime); }
  .sub {
    margin-top: 14px;
    color: var(--muted);
    font-size: 16px;
    max-width: 480px;
    margin-inline: auto;
  }
  .paddle-icon {
    font-size: 60px;
    margin-bottom: 8px;
    display: block;
    filter: drop-shadow(0 0 20px rgba(200,241,53,.4));
  }

  /* ── PILL TABS ── */
  .tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    padding: 36px 20px 0;
    flex-wrap: wrap;
  }
  .tab {
    padding: 10px 24px;
    border-radius: 999px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .tab:hover { border-color: var(--lime); color: var(--lime); }
  .tab.active {
    background: var(--lime);
    border-color: var(--lime);
    color: var(--dark);
  }
  .tab-icon { font-size: 16px; }

  /* ── SEARCH BOX ── */
  .search-wrap {
    max-width: 700px;
    margin: 28px auto 0;
    padding: 0 20px;
  }
  .search-row {
    display: flex;
    gap: 10px;
    background: var(--card-bg);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 8px 8px 8px 20px;
    transition: border-color .2s;
  }
  .search-row:focus-within { border-color: var(--lime); }
  #searchInput {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
  }
  #searchInput::placeholder { color: var(--muted); }
  #searchBtn {
    background: var(--lime);
    color: var(--dark);
    border: none;
    border-radius: 9px;
    padding: 10px 22px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    transition: opacity .2s, transform .1s;
    white-space: nowrap;
  }
  #searchBtn:hover { opacity: .88; }
  #searchBtn:active { transform: scale(.97); }
  #searchBtn:disabled { opacity: .45; cursor: default; }

  /* ── QUICK CHIPS ── */
  .chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 14px;
  }
  .chip {
    background: rgba(200,241,53,.08);
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 999px;
    font-size: 12px;
    padding: 5px 13px;
    cursor: pointer;
    transition: all .18s;
  }
  .chip:hover { background: rgba(200,241,53,.16); color: var(--lime); border-color: var(--lime); }

  /* ── RESULTS ── */
  #results {
    max-width: 820px;
    margin: 44px auto 80px;
    padding: 0 20px;
  }
  .status {
    text-align: center;
    color: var(--muted);
    font-size: 14px;
    padding: 16px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  /* spinner */
  .spinner {
    width: 18px; height: 18px;
    border: 2.5px solid var(--border);
    border-top-color: var(--lime);
    border-radius: 50%;
    animation: spin .7s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* result cards */
  .results-header {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--muted);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .results-header::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 24px;
    margin-bottom: 14px;
    transition: border-color .2s, transform .2s;
    animation: fadeUp .35s ease both;
  }
  .card:hover { border-color: rgba(200,241,53,.42); transform: translateY(-2px); }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .card-head {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 10px;
  }
  .card-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    background: rgba(200,241,53,.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .card-title {
    font-weight: 700;
    font-size: 17px;
    color: var(--white);
    line-height: 1.2;
  }
  .card-meta {
    font-size: 12px;
    color: var(--lime);
    font-weight: 600;
    margin-top: 3px;
    text-transform: uppercase;
    letter-spacing: .08em;
  }
  .card-body {
    font-size: 14px;
    color: #b0b89a;
    line-height: 1.65;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }
  .tag {
    background: rgba(255,107,26,.12);
    color: var(--orange);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border: 1px solid rgba(255,107,26,.25);
  }
  .tag.green {
    background: rgba(200,241,53,.1);
    color: var(--lime);
    border-color: rgba(200,241,53,.25);
  }

  /* empty state */
  .empty {
    text-align: center;
    padding: 60px 20px;
  }
  .empty-icon { font-size: 56px; margin-bottom: 16px; display: block; opacity: .4; }
  .empty h3 { font-size: 18px; margin-bottom: 8px; color: var(--muted); }

  /* footer */
  footer {
    text-align: center;
    padding: 20px;
    font-size: 12px;
    color: var(--muted);
    border-top: 1px solid var(--border);
  }
</style>
</head>
<body>

<header>
  <span class="paddle-icon">🏓</span>
  <div class="badge">Ontario Pickleball Hub</div>
  <h1>FIND YOUR<br/><span>PICKLEBALL</span><br/>COMMUNITY</h1>
  <p class="sub">Search for players, coaches, and tournaments across Ontario — powered by live web search.</p>
</header>

<div class="tabs">
  <button class="tab active" data-cat="players"><span class="tab-icon">🧑‍🤝‍🧑</span> Players</button>
  <button class="tab" data-cat="coaches"><span class="tab-icon">🎯</span> Coaches</button>
  <button class="tab" data-cat="tournaments"><span class="tab-icon">🏆</span> Tournaments</button>
  <button class="tab" data-cat="clubs"><span class="tab-icon">📍</span> Clubs & Courts</button>
</div>

<div class="search-wrap">
  <div class="search-row">
    <input id="searchInput" type="text" placeholder="e.g. Toronto, beginner, outdoor courts…" />
    <button id="searchBtn">Search →</button>
  </div>
  <div class="chips" id="quickChips"></div>
</div>

<div id="results">
  <div class="empty">
    <span class="empty-icon">🏓</span>
    <h3>Choose a category and search to get started</h3>
    <p style="color:var(--muted);font-size:13px;">Results are pulled live from the web</p>
  </div>
</div>

<footer>Ontario Pickleball Hub &nbsp;·&nbsp; Results powered by AI + Live Web Search</footer>

<script>
const QUICK = {
  players:     ['Toronto players', 'Ottawa competitive', 'Hamilton league', 'Beginners welcome'],
  coaches:     ['Certified coaches', 'Youth coaching', 'Ottawa coaches', 'Private lessons'],
  tournaments: ['2025 tournaments', 'Upcoming events', 'Open tournaments', 'Senior division'],
  clubs:       ['Toronto clubs', 'Indoor courts', 'Niagara region', 'Free courts'],
};

const ICONS = { players: '🧑‍🤝‍🧑', coaches: '🎯', tournaments: '🏆', clubs: '📍' };

let currentCat = 'players';

// tabs
document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    currentCat = t.dataset.cat;
    buildChips();
    document.getElementById('searchInput').placeholder = placeholderFor(currentCat);
  });
});

function placeholderFor(cat) {
  return {
    players: 'e.g. Toronto, 3.5 rating, doubles…',
    coaches: 'e.g. Ottawa, certified, youth…',
    tournaments: 'e.g. 2025, open division, Niagara…',
    clubs: 'e.g. indoor, free courts, GTA…',
  }[cat];
}

function buildChips() {
  const wrap = document.getElementById('quickChips');
  wrap.innerHTML = '';
  (QUICK[currentCat] || []).forEach(label => {
    const c = document.createElement('button');
    c.className = 'chip';
    c.textContent = label;
    c.onclick = () => { document.getElementById('searchInput').value = label; doSearch(); };
    wrap.appendChild(c);
  });
}
buildChips();

document.getElementById('searchBtn').addEventListener('click', doSearch);
document.getElementById('searchInput').addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });

async function doSearch() {
  const q = document.getElementById('searchInput').value.trim();
  const cat = currentCat;
  const resultsEl = document.getElementById('results');
  const btn = document.getElementById('searchBtn');

  const catLabel = { players: 'Players', coaches: 'Coaches', tournaments: 'Tournaments', clubs: 'Clubs & Courts' }[cat];
  const prompt = buildPrompt(cat, q);

  btn.disabled = true;
  btn.textContent = 'Searching…';
  resultsEl.innerHTML = `<div class="status"><div class="spinner"></div> Searching for ${catLabel} in Ontario${q ? ' — "' + q + '"' : ''}…</div>`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        system: `You are a pickleball information assistant specialised in Ontario, Canada. 
When asked about pickleball ${cat} in Ontario, search the web and return ONLY a JSON array (no markdown, no preamble) of result objects.
Each object must have these fields:
- "title": string (name of person, club, event etc.)
- "meta": string (short key detail: location, date, skill level etc.)
- "description": string (2-3 sentences of useful info)
- "tags": string[] (2-4 short keyword tags)

Return between 4 and 8 results. If real data is limited, include the best known options. Always return valid JSON array only.`,
        messages: [{ role: 'user', content: prompt }],
      })
    });

    const data = await response.json();
    // extract text blocks (the JSON is in a text block after tool use)
    const textBlocks = (data.content || []).filter(b => b.type === 'text');
    const rawText = textBlocks.map(b => b.text).join('');

    let items = [];
    try {
      // strip any accidental markdown fences
      const clean = rawText.replace(/```json|```/g, '').trim();
      // find first [ ... ] in case there's extra text
      const match = clean.match(/\[[\s\S]*\]/);
      if (match) items = JSON.parse(match[0]);
    } catch(e) {
      items = [];
    }

    renderResults(items, catLabel, q);
  } catch(err) {
    resultsEl.innerHTML = `<div class="status" style="color:var(--orange)">⚠️ Search failed. Please try again.</div>`;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Search →';
  }
}

function buildPrompt(cat, q) {
  const base = `Find information about pickleball ${cat} in Ontario, Canada`;
  if (!q) return base + '. Give a good general overview of the best options available.';
  return base + ` matching this query: "${q}". Focus results on this request.`;
}

function renderResults(items, catLabel, q) {
  const resultsEl = document.getElementById('results');
  if (!items || items.length === 0) {
    resultsEl.innerHTML = `
      <div class="empty">
        <span class="empty-icon">🔍</span>
        <h3>No results found</h3>
        <p style="color:var(--muted);font-size:13px;">Try a different search or browse the quick chips above.</p>
      </div>`;
    return;
  }

  const icon = ICONS[currentCat] || '🏓';
  let html = `<div class="results-header">${catLabel} in Ontario${q ? ' · "' + q + '"' : ''} — ${items.length} results</div>`;

  items.forEach((item, i) => {
    const tags = (item.tags || []).map((t, ti) =>
      `<span class="tag ${ti % 2 === 0 ? 'green' : ''}">${t}</span>`
    ).join('');
    html += `
      <div class="card" style="animation-delay:${i * 0.06}s">
        <div class="card-head">
          <div class="card-icon">${icon}</div>
          <div>
            <div class="card-title">${escHtml(item.title || 'Unknown')}</div>
            <div class="card-meta">${escHtml(item.meta || '')}</div>
          </div>
        </div>
        <div class="card-body">${escHtml(item.description || '')}</div>
        ${tags ? `<div class="card-tags">${tags}</div>` : ''}
      </div>`;
  });

  resultsEl.innerHTML = html;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
</body>
</html>
